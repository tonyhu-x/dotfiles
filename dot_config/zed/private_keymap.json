// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "unbind": {
      "cmd-j": "workspace::ToggleBottomDock",
      "ctrl-h": "editor::Backspace",
    },
    "bindings": {
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-j": "workspace::ActivatePaneDown",
      "cmd-j g": "git_panel::Toggle",
      "cmd-j e": "project_panel::Toggle",
      "cmd-j o": "outline_panel::Toggle",
      "cmd-j n": "multi_workspace::ToggleWorkspaceSidebar",
      "cmd-j a": "agent::Toggle",
      "cmd-j t": "terminal_panel::Toggle",
      "cmd-j d": "debug_panel::Toggle",
      "cmd-j s": "diagnostics::Deploy",
      "cmd-j h": "workspace::ToggleLeftDock",
      "cmd-j l": "workspace::ToggleRightDock",
      "cmd-j j": "workspace::ToggleBottomDock",
    },
  },
  {
    "context": "Pane",
    "bindings": {
      "cmd-1": ["pane::ActivateItem", 0],
      "cmd-2": ["pane::ActivateItem", 1],
      "cmd-3": ["pane::ActivateItem", 2],
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-s": "workspace::Save",
      "ctrl-alt-space": "editor::ShowCompletions",
    },
  },
  {
    "context": "Editor && showing_completions",
    "bindings": {
      "enter": "editor::Newline",
    },
  },
  {
    "context": "Editor && edit_prediction",
    "bindings": {
      "ctrl-alt-space": "editor::AcceptEditPrediction",
    },
    "unbind": {
      "alt-tab": "editor::AcceptEditPrediction",
      "tab": "editor::AcceptEditPrediction",
    },
  },
  {
    "context": "vim_mode == normal || vim_mode == visual",
    "bindings": {
      "s": "vim::PushSneak",
      "shift-s": "vim::PushSneakBackward",
    },
  },
  {
    "context": "vim_mode == insert",
    "unbind": {
      "ctrl-s": "editor::ShowSignatureHelp"
    }
  },
  {
    "context": "VimControl && !menu",
    "bindings": {
      "shift-h": "pane::ActivatePreviousItem",
      "shift-l": "pane::ActivateNextItem",
      "g r": "editor::FindAllReferences",
      "g o": "outline::Toggle",
      "'": ["vim::PushJump", { "line": false }],
      "`": ["vim::PushJump", { "line": true }],
    },
  },
]
